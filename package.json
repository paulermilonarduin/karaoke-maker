{
  "name": "karaoke-maker",
  "private": true,
  "version": "0.0.0",
  "description": "Interface web et desktop pour créer et jouer des karaokés synchronisés.",
  "author": "paulermilonarduin",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "npm run build:electron && concurrently -k \"npm run dev -- --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "typecheck": "vue-tsc -b",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "build": "vue-tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:desktop": "npm run build && npm run build:electron",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "electron:preview": "npm run build:desktop && electron .",
    "package:win": "npm run build:desktop && electron-builder --win"
  },
  "dependencies": {
    "vue": "^3.5.34",
    "wavesurfer.js": "^7.12.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.2.8",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.paulermilonarduin.karaokemaker",
    "productName": "Karaoke Maker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
